import java.time.LocalDate;
import java.util.ArrayList;
import java.util.List;

public class main {

    public static void main(String[] args) {

        // Create OrderManager (files where orders/customers will be stored)
        OrderManager manager = new OrderManager("orders.txt", "customers.txt");

        // Create Bakery Staff
        BakeryStaff staff = new BakeryStaff("S001", "admin", "1234");

        // Staff login
        staff.login("admin", "1234");

        // Create Customer
        Customer customer = staff.createCustomer(
                "C001",
                "John Brown",
                "john@email.com",
                "8761234567",
                "Kingston, Jamaica"
        );

        if (customer == null) {
            System.out.println("Customer creation failed.");
            return;
        }

        System.out.println("\nCustomer Created:");
        System.out.println(customer.getCustomerInfo());

        // Create Order Items
        List<OrderItem> items = new ArrayList<>();

        items.add(new OrderItem("Chocolate Cake", 1, 2500.00));
        items.add(new OrderItem("Cupcakes Box", 2, 1200.00));
        items.add(new OrderItem("Banana Bread", 1, 800.00));

        // Delivery Date
        LocalDate deliveryDate = LocalDate.now().plusDays(2);

        // Create Order
        Order order = staff.createOrder(manager, customer, items, deliveryDate);

        if (order != null) {

            System.out.println("\nOrder Created Successfully!\n");

            // Save Order
            manager.saveOrder(order);

            // Display Order Details
            System.out.println(order.getOrderDetails());

        } else {
            System.out.println("Order creation failed.");
        }

        // Logout staff
        staff.logout();
    }
}
